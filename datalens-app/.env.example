GEMINI_API_KEY=your_google_ai_studio_key_here

# Default stable models currently used by the app.
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# Recommended for free-tier keys if you want to avoid low Pro quotas.
# When true, every internal "pro" request is routed to the flash model.
GEMINI_DISABLE_PRO=false
